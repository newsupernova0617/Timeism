# ==================== 서버 설정 ====================
PORT=3000
DOMAIN=https://timeism.keero.site
NODE_ENV=development

# ==================== 보안 설정 ====================
# ⚠️ 프로덕션에서는 반드시 변경!
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=admin_secret_token_change_me
IP_HASH_SALT=default_ip_salt

# ==================== 레이트 리밋 ====================
RATE_LIMIT_MAX=30

# ==================== 프록시 설정 ====================
# Nginx, ALB 등 뒤에서 실행 시 설정
# TRUST_PROXY=1

# ==================== 데이터베이스 ====================
# DB_PATH=data/app.db

# ==================== Turso 데이터베이스 ====================
# Turso 클라우드 데이터베이스 설정
TURSO_CONNECTION_URL=libsql://synctime-dev-xxxxx.turso.io
TURSO_AUTH_TOKEN=your_auth_token_here

# ==================== R2 클라우드 스토리지 ====================
# Cloudflare R2 백업 설정
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=your-backup-bucket
R2_REGION=auto

# ==================== 백업 스케줄 ====================
# Cron 형식 (기본값: 매일 오전 2시)
# 참고: https://crontab.guru/
BACKUP_SCHEDULE=0 2 * * *
# 백업 파일 보관 기간 (일)
BACKUP_RETENTION_DAYS=7
