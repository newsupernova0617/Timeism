    </p>

    <div class="code-example" style="background-color: #fff9c4; padding: 1.5rem; margin: 1.5rem 0;">
        <pre style="background-color: #263238; color: #ffcb6b; padding: 1rem; overflow-x: auto;"><code class="language-javascript">async function getAccurateTime(url, samples = 5) {
  const results = [];
  
  // 5번 측정
  for (let i = 0; i < samples; i++) {
    const result = await checkServerTime(url);
    results.push(result);
    await sleep(100); // 100ms 대기
  }
  
  // RTT가 가장 짧은 3개 선택
  results.sort((a, b) => a.rtt - b.rtt);
  const best = results.slice(0, 3);
  
  // 평균 계산
  const avgTime = best.reduce((sum, r) => 
    sum + r.serverTime.getTime(), 0
  ) / best.length;
  
  return new Date(avgTime);
}
</code></pre>
