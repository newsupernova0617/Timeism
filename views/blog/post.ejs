<!DOCTYPE html>
<html lang="<%= locale %>">

<head>
    <%- include('../partials/meta') %>
        <title>
            <%= locale==='ko' ? post.title.ko : post.title.en %> · SyncTime Blog
        </title>
        <meta name="description" content="<%= locale === 'ko' ? post.description.ko : post.description.en %>">
        <meta name="keywords" content="<%= locale === 'ko' ? post.keywords?.ko || '티켓팅, 서버시간, SyncTime' : post.keywords?.en || 'ticketing, server time, SyncTime' %>">
        <link rel="canonical" href="<%= domain %>/<%= locale %>/blog/<%= post.slug %>" />
        <meta property="og:type" content="article" />
        <meta property="og:site_name" content="SyncTime - Server Time Comparison Service" />
        <meta property="og:title" content="<%= locale==='ko' ? post.title.ko : post.title.en %>" />
        <meta property="og:description" content="<%= locale === 'ko' ? post.description.ko : post.description.en %>" />
        <meta property="og:url" content="<%= domain %>/<%= locale %>/blog/<%= post.slug %>" />
        <meta property="og:image" content="<%= domain %>/og-image.png" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:type" content="image/png" />
        <meta property="og:locale" content="<%= locale === 'ko' ? 'ko_KR' : locale === 'jp' ? 'ja_JP' : locale === 'zh-tw' ? 'zh_TW' : 'en_US' %>" />
        <meta property="article:published_time" content="<%= post.date %>" />
        <meta property="article:modified_time" content="<%= post.date %>" />
        <meta property="article:author" content="SyncTime Team" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content="<%= locale==='ko' ? post.title.ko : post.title.en %>" />
        <meta name="twitter:description" content="<%= locale === 'ko' ? post.description.ko : post.description.en %>" />
        <meta name="twitter:image" content="<%= domain %>/og-image.png" />

        <!-- BreadcrumbList Schema -->
        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "<%= locale === 'ko' ? '홈' : 'Home' %>",
                    "item": "https://synctime.keero.site/<%= locale %>"
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "<%= locale === 'ko' ? '블로그' : 'Blog' %>",
                    "item": "https://synctime.keero.site/<%= locale %>/blog"
                },
                {
                    "@type": "ListItem",
                    "position": 3,
                    "name": "<%= locale === 'ko' ? post.title.ko : post.title.en %>",
                    "item": "https://synctime.keero.site/<%= locale %>/blog/<%= post.slug %>"
                }
            ]
        }
        </script>

        <!-- Schema.org BlogPosting Structured Data -->
        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "BlogPosting",
            "headline": "<%= locale === 'ko' ? post.title.ko : post.title.en %>",
            "description": "<%= locale === 'ko' ? post.description.ko : post.description.en %>",
            "image": "<%= domain %>/og-image.png",
            "datePublished": "<%= post.date %>",
            "dateModified": "<%= post.date %>",
            "author": {
                "@type": "Organization",
                "name": "SyncTime Team",
                "url": "<%= domain %>"
            },
            "publisher": {
                "@type": "Organization",
                "name": "SyncTime",
                "logo": {
                    "@type": "ImageObject",
                    "url": "<%= domain %>/favicon.svg"
                }
            },
            "mainEntityOfPage": {
                "@type": "WebPage",
                "@id": "<%= domain %>/<%= locale %>/blog/<%= post.slug %>"
            },
            "inLanguage": "<%= locale === 'ko' ? 'ko-KR' : (locale === 'en' ? 'en-US' : (locale === 'jp' ? 'ja-JP' : 'zh-TW')) %>",
            "keywords": "<%= locale === 'ko' ? '티켓팅, 서버시간, 시간동기화, SyncTime' : 'ticketing, server time, time synchronization, SyncTime' %>"
        }
        </script>

        <link rel="stylesheet" href="/css/tokens.css">
        <link rel="stylesheet" href="/css/style.css">
        <link rel="stylesheet" href="/css/seo-content.css">
        <style>
            .blog-content {
                max-width: 800px;
                margin: 0 auto;
                line-height: 1.7;
                font-size: 1.05rem;
            }

            .blog-content h2 {
                margin-top: var(--space-8);
                margin-bottom: var(--space-4);
                font-size: var(--font-size-xl);
                color: var(--color-brand);
            }

            .blog-content h3 {
                margin-top: var(--space-6);
                margin-bottom: var(--space-3);
                font-size: var(--font-size-lg);
            }

            .blog-content p,
            .blog-content ul,
            .blog-content ol {
                margin-bottom: var(--space-4);
            }

            .blog-content ul,
            .blog-content ol {
                padding-left: var(--space-5);
            }

            .blog-content li {
                margin-bottom: var(--space-2);
            }

            .blog-highlight {
                background: var(--color-surface-muted);
                padding: var(--space-4);
                border-radius: var(--radius-md);
                border-left: 4px solid var(--color-brand);
                margin: var(--space-6) 0;
            }
        </style>
</head>

<body>
    <div class="app-container">
        <main class="content-wrapper">
            <article class="blog-post">
                <!-- Breadcrumb Navigation -->
                <%- include('../partials/breadcrumb', { locale: locale, section: locale==='ko' ? '블로그' : (locale==='en'
                    ? 'Blog' : (locale==='jp' ? 'ブログ' : '部落格' )), sectionUrl: '/' + locale + '/blog' , currentPage:
                    locale==='ko' ? post.title.ko : (locale==='en' ? post.title.en : (locale==='jp' ? post.title.jp :
                    post.title.zh)) }) %>

                    <header class="page-header">
                        <div class="post-icon" style="font-size: 3rem; margin-bottom: var(--space-3);">
                            <%= post.icon %>
                        </div>
                        <h1>
                            <%= locale==='ko' ? post.title.ko : post.title.en %>
                        </h1>
                        <p class="subtitle">
                            <%= post.date %> · SyncTime Guide
                        </p>
                    </header>

                    <div class="blog-content">
                        <%# Include the specific post content based on slug %>
                            <%- include('posts/' + post.slug) %>
                    </div>

                    <!-- Social Share Buttons -->
                    <%- include('../partials/social-share', { locale: locale, post: post, domain: domain }) %>

                        <div class="post-footer" style="margin-top: var(--space-8); text-align: center;">
                            <a href="/<%= locale %>/blog" class="submit-btn"
                                style="display: inline-block; width: auto; text-decoration: none;">
                                <%= locale==='ko' ? '목록으로 돌아가기' : 'Back to Blog' %>
                            </a>
                        </div>
            </article>

            <%- include('../partials/comments', { locale: locale, pageId: 'blog-' + post.slug }) %>
        </main>

        <%- include('../partials/footer') %>
    </div>
</body>

</html>