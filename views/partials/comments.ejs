<%# 실시간 댓글 - Enter로 작성 %>
    <div class="live-comments-sidebar">
        <div class="sidebar-header">
            <h3 class="sidebar-title">
                <%= locale==='ko' ? '💬 실시간 댓글' : '💬 Live Comments' %>
                    <span class="comment-count-badge" id="commentsCount">0</span>
            </h3>
            <span class="char-count-header" id="charCount">0/200</span>
        </div>

        <%# 댓글 작성 폼 %>
            <form id="commentForm" class="compact-comment-form">
                <input type="hidden" name="pageId" value="<%= pageId %>">
                <input type="text" name="honeypot" style="display:none" tabindex="-1" autocomplete="off">

                <textarea id="commentContent" name="content" class="compact-textarea"
                    placeholder="<%= locale === 'ko' ? '댓글 입력 (Enter로 작성)...' : 'Write (Press Enter)...' %>"
                    maxlength="200" rows="2" required></textarea>
            </form>

            <%# 댓글 목록 %>
                <div class="compact-comments-list" id="commentsList">
                    <div class="loading-small" id="commentsLoading">
                        <%= locale==='ko' ? '로딩 중...' : 'Loading...' %>
                    </div>
                </div>
    </div>

    <style>
        .live-comments-sidebar {
            background: var(--color-surface);
            border-radius: 12px;
            padding: 1rem;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
            height: fit-content;
            max-height: 500px;
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.75rem;
        }

        .sidebar-title {
            font-size: 0.95rem;
            margin: 0;
            color: var(--color-text);
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .comment-count-badge {
            background: var(--color-primary);
            color: white;
            padding: 0.1rem 0.4rem;
            border-radius: 10px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        .char-count-header {
            font-size: 0.7rem;
            color: var(--color-text-secondary);
            font-weight: 500;
        }

        .compact-comment-form {
            margin-bottom: 0.75rem;
        }

        .compact-textarea {
            width: 100%;
            padding: 0.5rem;
            border: 1px solid var(--color-border);
            border-radius: 6px;
            font-size: 0.85rem;
            font-family: inherit;
            resize: none;
            transition: border-color 0.2s;
            box-sizing: border-box;
        }

        .compact-textarea:focus {
            outline: none;
            border-color: var(--color-primary);
        }

        .compact-comments-list {
            flex: 1;
            overflow-y: auto;
            max-height: 360px;
        }

        .compact-comment-item {
            padding: 0.5rem;
            margin-bottom: 0.4rem;
            background: rgba(0, 0, 0, 0.02);
            border-radius: 6px;
            border-left: 3px solid var(--color-primary);
            box-sizing: border-box;
        }

        .compact-comment-content {
            font-size: 0.85rem;
            color: var(--color-text);
            line-height: 1.3;
            word-break: break-word;
        }

        .loading-small {
            text-align: center;
            padding: 1rem;
            font-size: 0.85rem;
            color: var(--color-text-secondary);
        }

        .error-message-small {
            background: #fee;
            color: #c33;
            padding: 0.5rem;
            border-radius: 6px;
            font-size: 0.85rem;
            margin-bottom: 0.5rem;
        }

        /* 스크롤바 */
        .compact-comments-list::-webkit-scrollbar {
            width: 4px;
        }

        .compact-comments-list::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 2px;
        }

        .compact-comments-list::-webkit-scrollbar-thumb {
            background: #888;
            border-radius: 2px;
        }
    </style>

    <script>
        (function () {
            const pageId = '<%= pageId %>';
            const locale = '<%= locale %>';
            const form = document.getElementById('commentForm');
            const commentsList = document.getElementById('commentsList');
            const commentsCount = document.getElementById('commentsCount');
            const charCount = document.getElementById('charCount');
            const contentTextarea = document.getElementById('commentContent');

            // 글자 수 카운터
            if (contentTextarea && charCount) {
                contentTextarea.addEventListener('input', () => {
                    charCount.textContent = `${contentTextarea.value.length}/200`;
                });

                // Enter로 작성 (Shift+Enter는 줄바꿈)
                contentTextarea.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter' && !e.shiftKey) {
                        e.preventDefault();
                        form.dispatchEvent(new Event('submit'));
                    }
                });
            }

            // 댓글 불러오기
            async function loadComments() {
                try {
                    const response = await fetch(`/api/comments/${pageId}?limit=10`);
                    const data = await response.json();

                    if (data.success) {
                        commentsCount.textContent = data.total;
                        renderComments(data.comments);
                    }
                } catch (error) {
                    console.error('Failed to load comments:', error);
                }
            }

            // 댓글 렌더링
            function renderComments(comments) {
                if (comments.length === 0) {
                    commentsList.innerHTML = `<div class="loading-small">${locale === 'ko' ? '아직 댓글이 없습니다' : 'No comments yet'
                        }</div>`;
                    return;
                }

                commentsList.innerHTML = comments.map(comment => `
      <div class="compact-comment-item">
        <div class="compact-comment-content">${escapeHtml(comment.content)}</div>
      </div>
    `).join('');
            }

            // 댓글 작성
            if (form) {
                form.addEventListener('submit', async (e) => {
                    e.preventDefault();

                    const content = contentTextarea.value.trim();
                    if (!content) return;

                    const formData = new FormData(form);
                    const data = {
                        pageId: formData.get('pageId'),
                        content: content,
                        honeypot: formData.get('honeypot')
                    };

                    contentTextarea.disabled = true;

                    try {
                        const response = await fetch('/api/comments', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify(data)
                        });

                        const result = await response.json();

                        if (result.success) {
                            form.reset();
                            charCount.textContent = '0/200';
                            loadComments();
                        } else {
                            showMessage(result.error || (locale === 'ko' ? '실패' : 'Failed'));
                        }
                    } catch (error) {
                        console.error('Failed to post comment:', error);
                        showMessage(locale === 'ko' ? '실패' : 'Failed');
                    } finally {
                        contentTextarea.disabled = false;
                        contentTextarea.focus();
                    }
                });
            }

            // 메시지 표시
            function showMessage(message) {
                const messageDiv = document.createElement('div');
                messageDiv.className = 'error-message-small';
                messageDiv.textContent = message;
                form.parentNode.insertBefore(messageDiv, form);

                setTimeout(() => {
                    messageDiv.remove();
                }, 3000);
            }

            // HTML 이스케이프
            function escapeHtml(text) {
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }

            // 초기 로드 및 자동 새로고침
            loadComments();
            setInterval(loadComments, 30000);
        })();
    </script>