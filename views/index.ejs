                          <span class="site-icon">📦</span>
                          <h3 class="site-name">Amazon</h3>
                          <p class="site-desc">Lightning Deals</p>
                        </a>
                        <a href="/en/sites/ebay" class="site-card" style="border-color: #e53238;">
                          <span class="site-icon">🏪</span>
                          <h3 class="site-name">eBay</h3>
                          <p class="site-desc">Auction Sniping</p>
                        </a>
                        <a href="/en/sites/eventbrite" class="site-card" style="border-color: #f05537;">
                          <span class="site-icon">🎉</span>
