                          <p class="site-desc">Local Events</p>
                        </a>
                        <% } %>
              </div>
            </section>
            -->
    </section>

    <aside class="sidebar" role="complementary" aria-label="Advertisement Area">
      <div class="ad-slot" aria-hidden="true">
        <p class="ad-placeholder">Advertisement</p>
      </div>

      <div class="ad-slot" aria-hidden="true">
        <p class="ad-placeholder">Advertisement</p>
      </div>

      <div class="ad-slot" aria-hidden="true">
        <p class="ad-placeholder">Advertisement</p>
      </div>
    </aside>
  </main>

  <footer class="page-footer">
    <nav>
      <a href="/<%= locale %>/guide">
        <%= translations.footer.guide %>
      </a>
      <span aria-hidden="true">·</span>
      <a href="/<%= locale %>/privacy">
        <%= translations.footer.privacy %>
      </a>
      <span aria-hidden="true">·</span>
      <a href="https://github.com/newsupernova0617/Timeism/issues">
        <%= translations.footer.contact %>
      </a>
    </nav>
    <p class="footer-copy">Displayed time is an HTTP Date header-based estimate for reference only.</p>
  </footer>

  <script type="module" src="/js/main.js"></script>

  <!-- Advertisement Scripts -->

</body>

</html>