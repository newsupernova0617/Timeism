                      <p class="site-desc">음악 공연</p>
                    </a>
                    <a href="/ko/sites/yes24" class="site-card" style="border-color: #0066cc;">
                      <span class="site-icon">📚</span>
                      <h3 class="site-name">YES24</h3>
                      <p class="site-desc">문화 티켓</p>
                    </a>
                    <a href="/ko/sites/coupang" class="site-card" style="border-color: #ff5a00;">
                      <span class="site-icon">🛒</span>
                      <h3 class="site-name">쿠팡</h3>
                      <p class="site-desc">타임딜</p>
                    </a>
                    <a href="/ko/sites/university" class="site-card" style="border-color: #4a90e2;">
                      <span class="site-icon">🎓</span>
                      <h3 class="site-name">수강신청</h3>
                      <p class="site-desc">대학교</p>
                    </a>
                    <% } else { %>
